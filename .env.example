# ─────────────────────────────────────────────────────────────────────────
# AI Escape Pod — Cloud Environment Variables
# Copy to .env.local for dev | Set in Vercel dashboard for production
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED: Get at https://console.x.ai → API Keys
XAI_API_KEY=xai-your-key-here

# Model (xAI options: grok-beta | grok-2-latest | grok-2-1212 | grok-3-beta)
AI_MODEL=grok-beta

# Custom AI persona (what your AI "is")
SYSTEM_PROMPT=You are a helpful, direct, and intelligent AI assistant.

# Branding (shown in UI)
NEXT_PUBLIC_APP_NAME=AI Escape Pod
NEXT_PUBLIC_MODEL_DISPLAY=grok-beta
NEXT_PUBLIC_APP_DESCRIPTION=Your private AI — no limits, no tracking, always on.

# Model parameters
MAX_TOKENS=4096
TEMPERATURE=0.7

# Override API endpoint (swap to any OpenAI-compatible provider)
# xAI (default):  https://api.x.ai/v1
# OpenAI:         https://api.openai.com/v1  (change XAI_API_KEY to OPENAI key)
# Local Ollama:   http://localhost:11434/v1   (no key needed — set XAI_API_KEY=none)
# API_BASE_URL=https://api.x.ai/v1
